# Local development: copy to .env and fill in values
# cp .env.example .env
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ── Streamlit Cloud deployment ──────────────────────────────────────────────
# In Streamlit Cloud, set these as secrets (not env vars):
#   App settings → Secrets → paste TOML below:
#
#   SUPABASE_URL = "https://your-project.supabase.co"
#   SUPABASE_KEY = "your-anon-key"
#
# Streamlit Cloud exposes secrets as both st.secrets and os.environ,
# so the app picks them up automatically.
